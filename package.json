  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "valibot": "^1.3.1"
  }
}
