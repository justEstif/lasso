{
  "name": "@justestif/lasso",
  "version": "0.1.3",
  "description": "Harness-agnostic observational memory and linting CLI for coding agents.",
  "module": "index.ts",
  "bin": {
    "lasso": "./index.ts"
  },
  "man": [
    "./man/lasso.1"
  ],
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/justEstif/lasso#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justEstif/lasso.git"
  },
  "bugs": {
    "url": "https://github.com/justEstif/lasso/issues"
  },
  "keywords": [
    "agent",
    "bun",
    "cli",
    "lint",
    "memory",
    "observability",
    "pi"
  ],
  "files": [
    "AGENTS.md",
    "README.md",
    "drizzle",
    "index.ts",
    "logger.ts",
    "man",
    "src"
