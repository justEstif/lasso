const LASSO_COMMAND = ['lasso'];
const promptBySession = new Map<string, string>();
let lastObservedTokens = 0;

async function runLasso(args: string[]) {
  const child = Bun.spawn([...LASSO_COMMAND, ...args], {
    stderr: 'pipe',
    stdout: 'pipe',
  });

  const [stdout, stderr, exitCode] = await Promise.all([
    new Response(child.stdout).text(),
    new Response(child.stderr).text(),
    child.exited,
  ]);

  if (exitCode !== 0) {
    const detail = stderr.trim() || stdout.trim() || `exit ${exitCode}`;
    throw new Error(`lasso ${args.join(' ')} failed: ${detail}`);
  }

  return stdout.trim();
}

function partText(part: unknown): string {
  if (!part || typeof part !== 'object') return '';
  const record = part as Record<string, unknown>;
  for (const key of ['text', 'content']) {
    const value = record[key];
    if (typeof value === 'string') return value;
  }
  return '';
}

function messageText(parts: unknown[]) {
  return parts.map(partText).filter(Boolean).join('\n').trim();
}

async function shouldObserve(tokens: number): Promise<boolean> {
  try {
    const result = await runLasso(['memory', 'should-observe', '--tokens', String(tokens)]);
    return result.includes('"needed":true');
  } catch {
    return false;
  }
}

async function shouldReflect(): Promise<boolean> {
  try {
    const result = await runLasso(['memory', 'should-reflect']);
    return result.includes('"needed":true');
  } catch {
    return false;
  }
}

async function observeConversation(conversation: string, tokens: number) {
  await Promise.all([
    runLasso(['lint', 'scan', '--force'], { input: conversation }).catch(() => {}),
    runLasso(['memory', 'observe', '--force', '--tokens', String(tokens)], { input: conversation }),
  ]);
  lastObservedTokens = tokens;
}

async function triggerReflection() {
  try {
    const context = await runLasso(['memory', 'context', '--limit', '20']);
    if (context) await runLasso(['memory', 'reflect'], { input: context });
  } catch {
    // Non-critical — reflection will be retried on next threshold breach
  }
}

export const LassoPlugin = async () => {
  return {
    'chat.message': async (input: { sessionID: string }, output: { parts: unknown[] }) => {
      const prompt = messageText(output.parts);
      if (prompt.length > 0) promptBySession.set(input.sessionID, prompt);
    },

    'experimental.chat.system.transform': async (
      input: { sessionID?: string },
      output: { system: string[] },
    ) => {
      try {
        const prompt = input.sessionID ? promptBySession.get(input.sessionID) : undefined;
        const contextArgs = ['memory', 'context', '--limit', '10'];
        if (prompt) contextArgs.push('--query', prompt);
        const context = await runLasso(contextArgs);

        const workingArgs = ['memory', 'working'];
        const working = await runLasso(workingArgs);

        const sections: string[] = [];
        if (context && !context.includes('No relevant memory found')) {
          sections.push(`# Lasso Memory\n\n${context}`);
        }
        if (working && !working.includes('No working memory found')) {
          sections.push(`# Lasso Working Memory\n\n${working}`);
        }

        if (sections.length > 0) {
          output.system.push(`\n${sections.join('\n\n')}`);
        }
      } catch (error) {
        console.warn(
          `lasso memory context unavailable: ${error instanceof Error ? error.message : String(error)}`,
        );
      }
    },

    'event': async ({ event }: { event: { type: string } }) => {
      if (event.type === 'session.idle') {
        try {
          const tokens = lastObservedTokens;
          if (tokens > 0 && (await shouldObserve(tokens))) {
            await runLasso(['memory', 'observe', '--tokens', String(tokens), '--force'], {
              input: `Session completed with ~${tokens} tokens.`,
            });
          }
          if (await shouldReflect()) {
            await triggerReflection();
          }
        } catch {
          // Non-critical
        }
      }
    },

    'experimental.session.compacting': async (
      _input: { sessionID: string },
      output: { context: string[]; prompt?: string },
    ) => {
      try {
        const context = await runLasso(['memory', 'context', '--limit', '20']);
        const working = await runLasso(['memory', 'working']);

        const sections: string[] = [];
        if (context && !context.includes('No relevant memory found')) {
          sections.push(`Lasso memory context for compaction:\n${context}`);
        }
        if (working && !working.includes('No working memory found')) {
          sections.push(`Lasso working memory:\n${working}`);
        }

        if (sections.length > 0) {
          output.context.push(sections.join('\n\n'));
        }

        if (await shouldReflect()) {
          await triggerReflection();
        }
      } catch {
        // Non-critical — don't block compaction
      }
    },
  };
};
