const LASSO_COMMAND = ['lasso'];

async function runLasso(args: string[], input?: string) {
  const child = Bun.spawn([...LASSO_COMMAND, ...args], {
    stderr: 'pipe',
    stdin: input ? 'pipe' : 'ignore',
    stdout: 'pipe',
  });

  if (input && child.stdin) {
    child.stdin.write(input);
    child.stdin.end();
  }

  const [stdout, stderr, exitCode] = await Promise.all([
    new Response(child.stdout).text(),
    new Response(child.stderr).text(),
    child.exited,
  ]);

  if (exitCode !== 0) {
    const detail = stderr.trim() || stdout.trim() || `exit ${exitCode}`;
    throw new Error(`lasso ${args.join(' ')} failed: ${detail}`);
  }

  return stdout.trim();
}

async function main() {
  try {
    // Inject memory context into compaction
    const context = await runLasso(['memory', 'context', '--limit', '20']);
    const working = await runLasso(['memory', 'working']);

    const sections: string[] = [];
    if (context && !context.includes('No relevant memory found')) {
      sections.push(`Lasso memory context:\n${context}`);
    }
    if (working && !working.includes('No working memory found')) {
      sections.push(`Lasso working memory:\n${working}`);
    }

    if (sections.length > 0) {
      // Output plain text as additional context for compaction
      console.log(sections.join('\n\n'));
    }

    // Trigger reflection if needed
    const reflectCheck = await runLasso(['memory', 'should-reflect']);
    if (reflectCheck.includes('"needed":true')) {
      await runLasso(['memory', 'reflect'], { input: sections.join('\n\n') || 'compaction' });
    }
  } catch {
    // Non-critical — don't block compaction
  }

  process.exit(0);
}

main();
